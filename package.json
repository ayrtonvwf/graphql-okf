{
  "name": "graphql-okf",
  "version": "0.0.0",
  "description": "Generate and maintain an Open Knowledge Format (OKF) bundle from a GraphQL schema",
  "keywords": [
    "okf",
    "open-knowledge-format",
    "graphql",
    "introspection",
    "sdl",
    "schema",
    "knowledge-base",
    "ai-agents",
    "documentation",
    "codegen"
  ],
  "license": "MIT",
  "author": "ayrtonvwf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayrtonvwf/graphql-okf.git"
  },
  "bugs": {
    "url": "https://github.com/ayrtonvwf/graphql-okf/issues"
  },
  "homepage": "https://github.com/ayrtonvwf/graphql-okf#readme",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "graphql-okf": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "knip": "knip",
    "build": "tsdown",
    "prepack": "pnpm run build",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  },
  "dependencies": {
    "graphql": "^16.14.2"
  }
}
