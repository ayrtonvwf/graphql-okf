{
  "name": "graphql-okf",
  "version": "0.0.0",
  "description": "Generate and maintain an Open Knowledge Format (OKF) bundle from a GraphQL schema",
  "keywords": [
    "okf",
    "open-knowledge-format",
    "graphql",
    "introspection",
    "sdl",
    "schema",
    "knowledge-base",
    "ai-agents",
    "documentation",
    "codegen"
  ],
  "license": "MIT",
  "author": "ayrtonvwf",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "graphql-okf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "knip": "knip",
    "build": "tsup",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "knip": "^6.26.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
