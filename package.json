{
  "name": "graphql-okf",
  "version": "0.0.0",
  "description": "Generate and maintain an Open Knowledge Format (OKF) bundle from a GraphQL schema",
  "keywords": [
    "okf",
    "open-knowledge-format",
    "graphql",
    "introspection",
    "sdl",
    "schema",
    "knowledge-base",
    "ai-agents",
    "documentation",
    "codegen"
  ],
  "license": "MIT",
  "author": "ayrtonvwf",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "bin": {
    "graphql-okf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "knip": "^6.26.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
